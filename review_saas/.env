# ------------------------------
# ReviewSaaS Application Settings
# ------------------------------
# Access & Security
ACCESS_TOKEN_MIN=120
JWT_ALG=HS256
JWT_SECRET="supersecret256bitkeyhere"                  # CHANGE THIS to a strong, random 32+ char secret (use Railway Variables)

# Base URL of your deployed app (must be a valid URL without trailing slash usually)
# This was the cause of your Pydantic crash — now set to your real Railway domain
APP_BASE_URL="https://sentiment-analysis-production-ca50.up.railway.app"

# Cookie settings (leading dot allows sharing across subdomains if you add custom domains later)
COOKIE_DOMAIN=".up.railway.app"
COOKIE_SECURE=true                                     # Keep true in production (Railway uses HTTPS)

# Database URLs — REPLACE with real values from your Railway Postgres service
# (Get from Railway → Database service → Connect → Connection strings)
DATABASE_PUBLIC_URL="postgresql://username:password@host:port/dbname?sslmode=require"
DATABASE_URL="postgresql://username:password@host:port/dbname?sslmode=require"   # usually same as above for most setups

# Google API Keys — REPLACE with your real keys (store in Railway Variables)
GOOGLE_BUSINESS_API_KEY="AIzaSyDjQFzX3Wak4maUWhSXstPmnbBOOKGVGfc"
GOOGLE_MAPS_API_KEY="AIzaSyCZ2a7vc0r9k3U7IFAMRQnYgmZwdx5RYjg"
GOOGLE_PLACES_API_KEY="AIzaSyCZ2a7vc0r9k3U7IFAMRQnYgmZwdx5RYjg"

# OAuth Google — REPLACE client ID/secret with real ones from Google Cloud Console
# Redirect URI must exactly match what you registered in Google Console
OAUTH_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
OAUTH_GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
OAUTH_GOOGLE_REDIRECT_URI="https://sentiment-analysis-production-ca50.up.railway.app/api/auth/google/callback"

# Password & Security Policies
PASSLIB_MAX_PASSWORD_SIZE=1024
LOCKOUT_MINUTES=15
LOCKOUT_THRESHOLD=5
RESET_TOKEN_MINUTES=30
VERIFY_TOKEN_HOURS=24

# SMTP (email) Settings — REPLACE with real values (e.g., Gmail, SendGrid, Resend)
# For Gmail: use app password if 2FA enabled; host=smtp.gmail.com, port=587
SMTP_FROM_EMAIL="you@yourdomain.com"
SMTP_FROM_NAME="Review SaaS"
SMTP_HOST="smtp.yourhost.com"
SMTP_PORT=587
SMTP_USERNAME="you@yourdomain.com"
SMTP_PASSWORD="your_smtp_password"

# Optional: Railway auto-provides this at runtime — you can use it in code if needed
# (e.g., fallback or dynamic base URL in settings.py)
# RAILWAY_PUBLIC_DOMAIN=sentiment-analysis-production-ca50.up.railway.app
