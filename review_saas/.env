# --------------------------------------
# APP CORE CONFIG
# --------------------------------------
APP_NAME="ReviewSaaS"
DEBUG=true
ENV=production

APP_BASE_URL="https://sentiment-analysis-production-ca50.up.railway.app"
COOKIE_DOMAIN=".up.railway.app"
COOKIE_SECURE=true

# --------------------------------------
# AUTH & JWT CONFIG
# --------------------------------------
SECRET_KEY="supersecret-session-key"
JWT_SECRET="supersecret256bitkeyhere"
JWT_ALG=HS256
ACCESS_TOKEN_MIN=120

# --------------------------------------
# DATABASE CONFIG — REQUIRED
# --------------------------------------
DATABASE_URL="postgresql://username:password@host:port/dbname?sslmode=require"
DATABASE_PUBLIC_URL="postgresql://username:password@host:port/dbname?sslmode=require"

# --------------------------------------
# GOOGLE API KEYS
# --------------------------------------
GOOGLE_MAPS_API_KEY="AIzaSyCZ2a7vc0r9k3U7IFAMRQnYgmZwdx5RYjg"
GOOGLE_PLACES_API_KEY="AIzaSyCZ2a7vc0r9k3U7IFAMRQnYgmZwdx5RYjg"
GOOGLE_BUSINESS_API_KEY="AIzaSyDjQFzX3Wak4maUWhSXstPmnbBOOKGVGfc"

# --------------------------------------
# GOOGLE OAUTH 2.0
# --------------------------------------
OAUTH_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
OAUTH_GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
OAUTH_GOOGLE_REDIRECT_URI="https://sentiment-analysis-production-ca50.up.railway.app/api/auth/google/callback"

# --------------------------------------
# SECURITY POLICIES
# --------------------------------------
PASSLIB_MAX_PASSWORD_SIZE=1024
LOCKOUT_MINUTES=15
LOCKOUT_THRESHOLD=5
RESET_TOKEN_MINUTES=30
VERIFY_TOKEN_HOURS=24

# --------------------------------------
# SMTP / EMAIL CONFIG
# --------------------------------------
SMTP_FROM_EMAIL="you@yourdomain.com"
SMTP_FROM_NAME="Review SaaS"
SMTP_HOST="smtp.yourhost.com"
SMTP_PORT=587
SMTP_USERNAME="you@yourdomain.com"
SMTP_PASSWORD="your_smtp_password"
