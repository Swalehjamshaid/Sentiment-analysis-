# ==========================
# FASTAPI / SQLALCHEMY ENV
# ==========================

# --- Choose one DATABASE_URL depending on environment ---
# For Local Development (SQLite, no DB server needed)
DATABASE_URL="sqlite+aiosqlite:///./dev.db"

# For Production (PostgreSQL async)
# Replace the placeholders below with your actual DB credentials
# DATABASE_URL="postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>"

# Example:
# DATABASE_URL="postgresql+asyncpg://admin:secret123@db.example.com:5432/myappdb"

# --------------------------
# Debug / App Settings
# --------------------------
DEBUG=True
SECRET_KEY="replace_with_a_secure_random_string"

# Optional: other environment variables
# CORS_ORIGINS="http://localhost,http://127.0.0.1"
# LOG_LEVEL="info"
