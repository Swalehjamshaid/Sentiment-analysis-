# ------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------
# Use the Internal URL provided by Railway for better performance
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL="postgresql+asyncpg://postgres:YOUR_ACTUAL_PASSWORD_HERE@YOUR_HOST_HERE:5432/railway"

# Sync connection for admin/export tools
DATABASE_PUBLIC_URL="postgresql://postgres:YOUR_ACTUAL_PASSWORD_HERE@YOUR_HOST_HERE:5432/railway"

# ------------------------------------------
