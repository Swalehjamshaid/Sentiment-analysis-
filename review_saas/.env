# -------------------------------
# App & Debug
# -------------------------------
APP_NAME="ReviewSaaS"
ENV=production
DEBUG=true
SECRET_KEY="supersecret-session-key"

# -------------------------------
# Server (optional)
# -------------------------------
HOST="0.0.0.0"
PORT=8000

# -------------------------------
# App URLs & Cookies
# -------------------------------
APP_BASE_URL="https://sentiment-analysis-production-ca50.up.railway.app"
COOKIE_DOMAIN="sentiment-analysis-production-ca50.up.railway.app"
COOKIE_SECURE=true

SESSION_COOKIE_NAME="session"
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE="lax"

# -------------------------------
# Database (ASYNC driver + NUMERIC port REQUIRED)
# -------------------------------
# 🔥 Replace username, password, host, dbname with real values (do NOT leave 'port')
# 🔥 Use async driver (postgresql+asyncpg) and a numeric port (usually 5432)
DATABASE_URL="postgresql+asyncpg://username:password@host:5432/dbname?sslmode=require"
DATABASE_PUBLIC_URL="postgresql+asyncpg://username:password@host:5432/dbname?sslmode=require"

# If Railway gives you a URL like:
#   postgresql://postgres:pass@containers-123.railway.app:12345/railway
# Convert it to:
#   postgresql+asyncpg://postgres:pass@containers-123.railway.app:12345/railway
# (and set that as DATABASE_URL in Railway → Project → Variables)

# -------------------------------
# JWT & Authentication
# -------------------------------
JWT_ALG="HS256"
JWT_SECRET="f3a8b2c9d1e5f0a7b3c8d2e6f9a0b1c2d3e4f5g6h7i8j9k0"
ACCESS_TOKEN_EXPIRE_MINUTES=120

LOCKOUT_MINUTES=30
LOCKOUT_THRESHOLD=5
VERIFY_TOKEN_HOURS=24
RESET_TOKEN_MINUTES=30
PASSLIB_MAX_PASSWORD_SIZE=72

