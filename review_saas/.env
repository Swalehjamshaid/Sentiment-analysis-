# -------------------------------
# App & Debug
# -------------------------------
APP_NAME="ReviewSaaS"
ENV=production
DEBUG=true
SECRET_KEY="supersecret-session-key"

# -------------------------------
# App URLs & Cookies
# -------------------------------
APP_BASE_URL="https://sentiment-analysis-production-ca50.up.railway.app"
COOKIE_DOMAIN="sentiment-analysis-production-ca50.up.railway.app"
COOKIE_SECURE=true

SESSION_COOKIE_NAME="session"
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE="lax"

# -------------------------------
# Database (ASYNC DRIVER + REAL PORT)
# -------------------------------
# 🔥 Replace username, password, host, dbname with REAL values from Railway.
# 🔥 Port MUST be numeric (5432). Do NOT leave "port".

DATABASE_URL="postgresql+asyncpg://username:password@host:5432/dbname?sslmode=require"
DATABASE_PUBLIC_URL="postgresql+asyncpg://username:password@host:5432/dbname?sslmode=require"

# If using Railway's built-in env vars instead:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# DATABASE_PUBLIC_URL=${{Postgres.DATABASE_PUBLIC_URL}}

# -------------------------------
# JWT & Authentication
# -------------------------------
JWT_ALG="HS256"
JWT_SECRET="f3a8b2c9d1e5f0a7b3c8d2e6f9a0b1c2d3e4f5g6h7i8j9k0"
ACCESS_TOKEN_EXPIRE_MINUTES=120

LOCKOUT_MINUTES=30
LOCKOUT_THRESHOLD=5
VERIFY_TOKEN_HOURS=24
RESET_TOKEN_MINUTES=30
PASSLIB_MAX_PASSWORD_SIZE=72

# -------------------------------
# Google APIs
# -------------------------------
GOOGLE_BUSINESS_API_KEY="AIzaSyDjQFzX3Wak4maUWhSXstPmnbBOOKGVGfc"
GOOGLE_MAPS_API_KEY="AIzaSyCZ2a7vc0r9k3U7IFAMRQnYgmZwdx5RYjg"
GOOGLE_PLACES_API_KEY="AIzaSyCZ2a7vc0r9k3U7IFAMRQnYgmZwdx5RYjg"

# -------------------------------
# OAuth (Google)
# -------------------------------
OAUTH_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
OAUTH_GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
OAUTH_GOOGLE_REDIRECT_URI="https://sentiment-analysis-production-ca50.up.railway.app/auth/google/callback"

# -------------------------------
# SMTP (Emails)
# -------------------------------
SMTP_FROM_EMAIL="you@example.com"
SMTP_FROM_NAME="ReviewSaaS"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="you@example.com"
SMTP_PASSWORD="YOUR_GMAIL_APP_PASSWORD"
