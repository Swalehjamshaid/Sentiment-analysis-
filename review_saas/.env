# ------------------------------
# ReviewSaaS Application Settings
# ------------------------------

# Access & Security
ACCESS_TOKEN_MIN=120
JWT_ALG=HS256
JWT_SECRET="supersecret256bitkeyhere"

# Base URL of your deployed app (must be a valid URL)
APP_BASE_URL="https://sentiment-analysis-production-ca50.up.railway.app"

# Cookie settings
COOKIE_DOMAIN=".up.railway.app"
COOKIE_SECURE=true

# Database URLs (replace with your Railway Postgres service URLs)
DATABASE_PUBLIC_URL="postgresql://username:password@host:port/dbname"
DATABASE_URL="postgresql://username:password@host:port/dbname"

# Google API Keys
GOOGLE_BUSINESS_API_KEY="YOUR_REAL_GOOGLE_BUSINESS_API_KEY"
GOOGLE_MAPS_API_KEY="YOUR_REAL_GOOGLE_MAPS_API_KEY"
GOOGLE_PLACES_API_KEY="YOUR_REAL_GOOGLE_PLACES_API_KEY"

# OAuth Google
OAUTH_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
OAUTH_GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
OAUTH_GOOGLE_REDIRECT_URI="https://sentiment-analysis-production-ca50.up.railway.app/api/auth/google/callback"

# Password & Security Policies
PASSLIB_MAX_PASSWORD_SIZE=1024
LOCKOUT_MINUTES=15
LOCKOUT_THRESHOLD=5
RESET_TOKEN_MINUTES=30
VERIFY_TOKEN_HOURS=24

# SMTP (email) Settings
SMTP_FROM_EMAIL="you@yourdomain.com"
SMTP_FROM_NAME="Review SaaS"
SMTP_HOST="smtp.yourhost.com"
SMTP_PORT=587
SMTP_USERNAME="you@yourdomain.com"
SMTP_PASSWORD="your_smtp_password"
